<Window x:Class="WpfComboCascade.CodeBehind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Code-Behind 级联 ComboBox"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterScreen">
    <Border Padding="24" Background="#FFF7F7F7">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,20">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="WPF Code-Behind 级联示例" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#FF666666"
                           Text="第 1 行选中后，第 2 到第 6 行自动显示后续数字，超出 6 的位置为空。" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="第 1 行" />
                <ComboBox x:Name="ComboBox1"
                          Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,0,0,12"
                          SelectionChanged="ComboBox1_OnSelectionChanged" />

                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="第 2 行" />
                <ComboBox x:Name="ComboBox2"
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,0,0,12"
                          IsEnabled="False" />

                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="第 3 行" />
                <ComboBox x:Name="ComboBox3"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,0,0,12"
                          IsEnabled="False" />

                <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="第 4 行" />
                <ComboBox x:Name="ComboBox4"
                          Grid.Row="3"
                          Grid.Column="1"
                          Margin="0,0,0,12"
                          IsEnabled="False" />

                <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="第 5 行" />
                <ComboBox x:Name="ComboBox5"
                          Grid.Row="4"
                          Grid.Column="1"
                          Margin="0,0,0,12"
                          IsEnabled="False" />

                <TextBlock Grid.Row="5" VerticalAlignment="Center" Text="第 6 行" />
                <ComboBox x:Name="ComboBox6"
                          Grid.Row="5"
                          Grid.Column="1"
                          IsEnabled="False" />
            </Grid>

            <TextBlock Grid.Row="2"
                       Margin="0,20,0,0"
                       VerticalAlignment="Top"
                       Foreground="#FF666666"
                       Text="示例：第 1 行选 3 时，第 2 到第 6 行会显示 4、5、6、空、空。" />
        </Grid>
    </Border>
</Window>
